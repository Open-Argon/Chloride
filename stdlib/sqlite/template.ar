class SQL_QUERY do

class __sql_templater__ do
  this.__template__(self, values) = do
    let query = SQL_QUERY()
    query.__statement__ = ""
    query.__values__ = []
    for (i in 0 until values.length) do
      let item = values[i]
      if (item[0]) do
        query.__statement__ = query.__statement__+item[1]
        continue
      query.__statement__=query.__statement__+"?"
      query.__values__.append(item[1])
    return query

let sql = __sql_templater__()